# Chạy 1 lần để xóa 3 dòng trùng trước khi upload Kaggle
import json
from collections import defaultdict

for fname in ['haui_qa_train.jsonl', 'haui_qa_val.jsonl']:
    data = [json.loads(l) for l in open(fname) if l.strip()]
    seen, clean = set(), []
    for d in data:
        q = d['instruction'].strip().lower()
        if q not in seen:
            seen.add(q)
            clean.append(d)
    with open(fname, 'w', encoding='utf-8') as f:
        for d in clean:
            f.write(json.dumps(d, ensure_ascii=False) + '\n')
    print(f'{fname}: {len(data)} → {len(clean)} (xóa {len(data)-len(clean)})')